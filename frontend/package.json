    "vue-router": "^3.6.5",
    "vue-sweetalert2": "^5.0.10",
    "wangeditor": "^4.7.15"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.26.0",
    "@vue/cli-plugin-babel": "~5.0.9",
    "@vue/cli-plugin-eslint": "~5.0.9",
